### UNIÓN DE LAS BASES ###
# Bases a unir
# Disponibles en: https://www.inegi.org.mx/programas/enoe/15ymas/#microdatos
sdemt <- read.csv("ENOE_SDEMT105.csv",header=T)
CO1<- read.csv("ENOE_COE1T105.csv",header=T)
CO2<- read.csv("ENOE_COE2T105.csv",header=T)

sdemt2 <- sdemt %>%
  filter(
    eda >= 12,            # personas mayores de 12 años
    eda != 99,
    c_res %in% c(1, 3),  # residentes habituales o temporales
    r_def == 0 # entrevista completa
  )

# Llanves para la unión 
#Llave cuestionario Sociodemográfico
sdemt2 <- sdemt2 %>%
  mutate(llave = paste(cd_a, ent, con, v_sel, n_hog, h_mud, n_ren, sep="_"))
summary(duplicated(sdemt2$llave))

#Llave COE1
CO1 <- CO1 %>%
  mutate(llave = paste(cd_a, ent, con, v_sel, n_hog, h_mud, n_ren, sep="_"))
summary(duplicated(CO1$llave))

#Llave COE2
CO2 <- CO2 %>%
  mutate(llave = paste(cd_a, ent, con, v_sel, n_hog, h_mud, n_ren, sep = "_"))
summary(duplicated(CO2$llave))

# Paso 1: Unir sdemt con CO1 usando la variable 'llave'
base_completa <- merge(sdemt2, CO1, by = "llave", all.x = TRUE)

# Paso 2: Unir el resultado con CO2
base_completa <- merge(base_completa, CO2, by = "llave", all.x = TRUE)


